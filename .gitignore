# Committed test fixtures (small, synthetic) — these MUST be tracked so the
# offline-decrypt regression tests actually run in CI; the *.pcapng / *.log rules
# above would otherwise exclude them.
!tests/fixtures/*.pcapng
!tests/fixtures/*.tls.log
!tests/fixtures/*.signal.log

